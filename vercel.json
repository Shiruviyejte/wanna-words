{
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "**"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "app/main" },
    { "src": "/docs", "dest": "app/main" },
    { "src": "/docs/?(.*)", "dest": "app/main" },
    { "src": "/openapi.json", "dest": "app/main" },
    { "src": "/favicon.ico", "dest": "app/main" },
    { "src": "/(.*)", "dest": "app/main" }
  ]
}
